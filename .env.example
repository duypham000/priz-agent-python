# ─── App ────────────────────────────────────────────────────────────────────
APP_PORT=8200
APP_ENV=development
LOG_LEVEL=INFO

# ─── Database: MySQL (sessions, quota, users) ────────────────────────────────
MYSQL_URL=mysql+aiomysql://pagent:pagent@localhost:3316/pagent

# ─── Database: PostgreSQL + pgvector (long-term memory, checkpointing) ───────
POSTGRES_URL=postgresql+asyncpg://pagent:pagent@localhost:5442/pagent

# ─── Cache / Short-term memory: Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6389/0

# ─── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-at-least-32-chars-long!!

# ─── LLM Providers ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
BEEKNOEE_API_KEY=your-beeknoee-api-key-here
BEEKNOEE_BASE_URL=https://api.beeknoee.com

# ─── Tools ────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key-here

# ─── Observability ────────────────────────────────────────────────────────────
PHOENIX_ENDPOINT=http://localhost:6016
PROMETHEUS_PORT=9290
